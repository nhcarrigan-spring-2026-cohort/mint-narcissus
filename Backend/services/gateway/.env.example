PORT=8080

# Must match the JWT_SECRET used by auth-service
JWT_SECRET=jwt-secret

# Downstream service URLs
# In Docker Compose, use service names as hostnames
AUTH_SERVICE_URL=http://auth-service:3001
ITEMS_SERVICE_URL=http://items-service:3002
REQUESTS_SERVICE_URL=http://requests-service:3003
MESSAGING_SERVICE_URL=http://messaging-service:3004

# For local dev (running services directly without Docker):
# AUTH_SERVICE_URL=http://localhost:3001
# ITEMS_SERVICE_URL=http://localhost:3002
# REQUESTS_SERVICE_URL=http://localhost:3003
# MESSAGING_SERVICE_URL=http://localhost:3004
